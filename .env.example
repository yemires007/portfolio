# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1

# --- Email notifications (optional) ---
# If these are left blank, the contact form still works and saves messages
# to the database — it just won't send you an email.
#
# For Gmail: turn on 2-Step Verification, then create an "App Password"
# (Google Account -> Security -> App passwords) and paste it as MAIL_PASSWORD.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
# Where contact-form messages get delivered:
MAIL_TO=alaooluwaseyi007@gmail.com
