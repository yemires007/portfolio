# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1

# --- Email notifications (optional) ---
# The contact form emails you via Web3Forms over HTTPS (works on hosts like
# Render that block SMTP). If this is blank, the form still works and saves
# messages to the database — it just won't email you.
#
# Get a free access key at https://web3forms.com (enter your email; the key is
# emailed to you). Set it in your host's environment, not in code.
WEB3FORMS_ACCESS_KEY=
